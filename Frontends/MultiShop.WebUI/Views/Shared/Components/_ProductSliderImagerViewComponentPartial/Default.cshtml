@model MultiShop.DTOLayer.CatalogDTOs.ProductImageDTO.GetByIdProductImageDTO

<div class="col-lg-5 mb-30">
    <div id="product-carousel" class="carousel slide" data-ride="carousel">
        <div class="carousel-inner bg-light">
            @if (Model != null)
            {
                <div class="carousel-item active">
                    <img class="w-100 h-100" src="@Model.Image1" alt="Ürün Görseli 1" style="object-fit: cover;">
                </div>
                @if (!string.IsNullOrEmpty(Model.Image2))
                {
                    <div class="carousel-item">
                        <img class="w-100 h-100" src="@Model.Image2" alt="Ürün Görseli 2" style="object-fit: cover;">
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Image3))
                {
                    <div class="carousel-item">
                        <img class="w-100 h-100" src="@Model.Image3" alt="Ürün Görseli 3" style="object-fit: cover;">
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Image4))
                {
                    <div class="carousel-item">
                        <img class="w-100 h-100" src="@Model.Image4" alt="Ürün Görseli 4" style="object-fit: cover;">
                    </div>
                }
            }
            else
            {
                <div class="carousel-item active">
                    <img class="w-100 h-100" src="~/images/no-image.png" alt="Görsel Yok">
                </div>
            }
        </div>
        <a class="carousel-control-prev" href="#product-carousel" data-slide="prev">
            <i class="fa fa-2x fa-angle-left text-dark"></i>
        </a>
        <a class="carousel-control-next" href="#product-carousel" data-slide="next">
            <i class="fa fa-2x fa-angle-right text-dark"></i>
        </a>
    </div>
</div>