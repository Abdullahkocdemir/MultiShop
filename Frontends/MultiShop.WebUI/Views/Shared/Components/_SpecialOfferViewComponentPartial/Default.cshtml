@model List<MultiShop.DTOLayer.CatalogDTOs.SpecialOfferDTO.ResultSpecialOfferDTO>

<div class="col-lg-4">
    @if (Model != null && Model.Count > 0)
    {
        @foreach (var item in Model)
        {
            <div class="product-offer mb-30" style="height: 200px;">
                <img class="img-fluid" src="@item.ImageUrl" alt="@item.Title">
                <div class="offer-text">
                    <h6 class="text-white text-uppercase">@item.SubTitle</h6>
                    <h3 class="text-white mb-3">@item.Title</h3>
                    <a href="" class="btn btn-primary">Hemen Al</a>
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center p-4 bg-white rounded shadow-sm">
            <p class="text-muted">Aktif kampanya bulunamadı.</p>
        </div>
    }
</div>