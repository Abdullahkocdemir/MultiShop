@model CreateLoginDTO
@{
    ViewData["Title"] = "Giriş Yap";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <title>Giriş Yap - MultiShop</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">

    <link rel="stylesheet" type="text/css" href="~/colorlib-regform-30/css/opensans-font.css">
    <link rel="stylesheet" type="text/css" href="~/colorlib-regform-30/fonts/line-awesome/css/line-awesome.min.css">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

    <link rel="stylesheet" href="~/colorlib-regform-30/css/style.css" />

    <style>
        body {
            background: #f2f2f2;
        }

        .form-v4-content {
            box-shadow: 0px 15px 25px rgba(0,0,0,0.1);
            border-radius: 10px;
        }

        .login-btn {
            background: #3786bd;
            border: none;
            width: 160px;
            height: 50px;
            border-radius: 5px;
            color: white;
            font-weight: 700;
            cursor: pointer;
            transition: 0.3s;
        }

            .login-btn:hover {
                background: #3e49bb;
            }

        .form-left {
            background: #3786bd;
        }
    </style>
</head>
<body class="form-v4">
    <div class="page-content">
        <div class="form-v4-content">
            <div class="form-left">
                <h2>MultiShop</h2>
                <p class="text-1">Tekrar hoş geldiniz! Hesabınıza giriş yaparak siparişlerinizi takip edebilir, favori ürünlerinize göz atabilirsiniz.</p>
                <p class="text-2"><span>Güvenlik:</span> Hesabınızın güvenliği bizim için önemli. Lütfen bilgilerinizi kimseyle paylaşmayın.</p>
                <div class="form-left-last">
                    <p style="color:white; margin-bottom:10px;">Henüz hesabın yok mu?</p>
                    <a href="/Register/Index" class="account" style="text-align:center; display:block; text-decoration:none; line-height:45px; border-radius: 5px;">Hemen Kayıt Ol</a>
                </div>
            </div>

            <form action="/Login/Index" method="post" class="form-detail" id="loginForm">
                <h2>GİRİŞ YAP</h2>

                <div class="form-row">
                    <label for="Username">Kullanıcı Adı</label>
                    <input type="text" asp-for="UserName" class="input-text" required placeholder="Kullanıcı adınız">
                </div>

                <div class="form-row">
                    <label for="Password">Şifre</label>
                    <input type="password" asp-for="Password" class="input-text" required placeholder="******">
                </div>

                <div class="form-checkbox">
                    <label class="container">
                        <p>Beni Hatırla</p>
                        <input type="checkbox" name="RememberMe">
                        <span class="checkmark"></span>
                    </label>
                </div>

                <div class="form-row-last" style="margin-top: 30px;">
                    <input type="submit" value="Giriş Yap" class="login-btn">
                </div>

                <div style="margin-top: 15px; text-align: center;">
                    <a href="#" style="color:#666; font-size:14px; text-decoration:none;">Şifremi Unuttum</a>
                </div>
            </form>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $('#loginForm').on('submit', function (e) {
            if (this.checkValidity()) {
                Swal.fire({
                    title: 'Giriş Yapılıyor',
                    text: 'Lütfen bekleyin...',
                    allowOutsideClick: false,
                    showConfirmButton: false,
                    didOpen: () => { Swal.showLoading(); }
                });
            }
        });
    </script>

    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            Swal.fire({
                icon: 'error',
                title: 'Hata!',
                text: '@TempData["ErrorMessage"]',
                confirmButtonText: 'Tamam'
            });
        </script>
    }
</body>
</html>