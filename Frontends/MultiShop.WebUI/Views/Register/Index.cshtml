@model MultiShop.DTOLayer.IdentityDTOs.RegisterDTO.CreateRegisterDTO

@{
    ViewData["Title"] = "Kayıt Ol";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <title>Kayıt Formu - MultiShop</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">

    <!-- Fontlar -->
    <link rel="stylesheet" type="text/css" href="~/colorlib-regform-30/css/opensans-font.css">
    <link rel="stylesheet" type="text/css" href="~/colorlib-regform-30/fonts/line-awesome/css/line-awesome.min.css">

    <!-- SweetAlert2 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

    <!-- Ana Stil Dosyası -->
    <link rel="stylesheet" href="~/colorlib-regform-30/css/style.css" />

    <style>
        body {
            background: #f2f2f2;
        }

        .form-v4-content {
            box-shadow: 0px 15px 25px rgba(0,0,0,0.1);
            border-radius: 10px;
        }

        .register:hover {
            background-color: #3e49bb !important;
            cursor: pointer;
            transition: 0.3s;
        }

        .form-left .text-1 {
            margin-bottom: 20px;
            line-height: 1.6;
        }

        .form-left span {
            font-weight: 700;
            color: #fff;
        }
    </style>
</head>
<body class="form-v4">
    <div class="page-content">
        <div class="form-v4-content">
            <!-- SOL PANEL: Yazıların olduğu kısım -->
            <div class="form-left">
                <h2>MultiShop</h2>
                <p class="text-1">MultiShop dünyasına hoş geldiniz! En kaliteli ürünlere, en uygun fiyatlarla ulaşmak için aramıza katılın. Alışverişin keyfini güvenle çıkarın.</p>
                <p class="text-2"><span>Ayrıcalıklar:</span> Üye olarak size özel indirimlerden ve kampanyalardan anında haberdar olabilirsiniz. Kişiselleştirilmiş alışveriş deneyimi sizi bekliyor.</p>
                <div class="form-left-last">
                    <a href="/Login/Index" class="account" style="text-align:center; display:block; text-decoration:none; line-height:45px; border-radius: 5px;">Zaten Üyeyim</a>
                </div>
            </div>

            <!-- SAĞ PANEL: Kayıt Formu -->
            <form action="/Register/Index" method="post" class="form-detail" id="registerForm">
                <h2>YENİ ÜYELİK</h2>

                <div class="form-group">
                    <div class="form-row form-row-1">
                        <label for="Name">Adınız</label>
                        <input type="text" name="Name" class="input-text" required>
                    </div>
                    <div class="form-row form-row-1">
                        <label for="Surname">Soyadınız</label>
                        <input type="text" name="Surname" class="input-text" required>
                    </div>
                </div>

                <div class="form-row">
                    <label for="Username">Kullanıcı Adı</label>
                    <input type="text" name="Username" class="input-text" required>
                </div>

                <div class="form-row">
                    <label for="Email">E-posta Adresiniz</label>
                    <input type="email" name="Email" class="input-text" required>
                </div>

                <div class="form-group">
                    <div class="form-row form-row-1">
                        <label for="Password">Şifre</label>
                        <input type="password" name="Password" id="txtPassword" class="input-text" required>
                    </div>
                    <div class="form-row form-row-1">
                        <label for="ConfirmPassword">Şifre Tekrar</label>
                        <input type="password" name="ConfirmPassword" class="input-text" required>
                    </div>
                </div>

                <div class="form-checkbox">
                    <label class="container">
                        <p>I agree to the <a href="#" class="text">Terms and Conditions</a></p>
                        <input type="checkbox" name="checkbox" required>
                        <span class="checkmark"></span>
                    </label>
                </div>

                <div class="form-row-last">
                    <input type="submit" value="Kayıt Ol" class="register">
                </div>
            </form>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // Form gönderildiğinde loading ekranı gelsin
        $('#registerForm').on('submit', function (e) {
            if (this.checkValidity()) {
                Swal.fire({
                    title: 'Lütfen Bekleyin',
                    text: 'Bilgileriniz işleniyor...',
                    allowOutsideClick: false,
                    showConfirmButton: false,
                    didOpen: () => { Swal.showLoading(); }
                });
            }
        });
    </script>

    @* Başarı Mesajı Kontrolü *@
    @if (TempData["SuccessMessage"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'Harika!',
                text: 'Kaydınız başarıyla tamamlandı. Giriş ekranına yönlendiriliyorsunuz.',
                timer: 3000,
                showConfirmButton: false
            }).then(() => {
                window.location.href = '/Login/Index';
            });
        </script>
    }

    @* Hata Mesajı Kontrolü *@
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            Swal.fire({
                icon: 'error',
                title: 'Hata!',
                text: '@TempData["ErrorMessage"]',
                confirmButtonText: 'Tamam'
            });
        </script>
    }
</body>
</html>