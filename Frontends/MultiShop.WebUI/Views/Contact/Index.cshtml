@model CreateContactDto

@{
    ViewData["Title"] = "İletişim";
    Layout = "~/Views/UILayout/Index.cshtml";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container-fluid">
    <div class="row px-xl-5">
        <div class="col-12">
            <nav class="breadcrumb bg-light mb-30">
                <a class="breadcrumb-item text-dark" href="/Default/Index">Ana Sayfa</a>
                <span class="breadcrumb-item active">İletişim</span>
            </nav>
        </div>
    </div>
</div>

<div class="container-fluid">
    <h2 class="section-title position-relative text-uppercase mx-xl-5 mb-4">
        <span class="bg-secondary pr-3">Bize Ulaşın</span>
    </h2>
    <div class="row px-xl-5">
        <div class="col-lg-7 mb-5">
            <div class="contact-form bg-light p-30">
                <form method="post">
                    <div class="control-group mb-3">
                        <input type="text" class="form-control" asp-for="NameSurname" placeholder="Adınız Soyadınız" required />
                    </div>
                    <div class="control-group mb-3">
                        <input type="email" class="form-control" asp-for="Email" placeholder="Email Adresiniz" required />
                    </div>
                    <div class="control-group mb-3">
                        <input type="text" class="form-control" asp-for="Subject" placeholder="Konu" required />
                    </div>
                    <div class="control-group mb-3">
                        <textarea class="form-control" rows="8" asp-for="Message" placeholder="Mesajınız" required></textarea>
                    </div>
                    <div>
                        <button class="btn btn-primary py-2 px-4" type="submit" id="sendMessageButton">
                            Mesajı Gönder
                        </button>
                    </div>
                </form>
            </div>
        </div>

        @await Component.InvokeAsync("_ContactMapViewComponentPartial")

        <div class="col-lg-5 mb-5">
            <div class="bg-light p-30 mb-30">
                <div class="d-flex mb-3">
                    <h5 class="font-weight-semi-bold m-0"><i class="fa fa-map-marker-alt text-primary mr-3"></i>123 Sokak, İstanbul, Türkiye</h5>
                </div>
                <div class="d-flex mb-3">
                    <h5 class="font-weight-semi-bold m-0"><i class="fa fa-envelope text-primary mr-3"></i>info@ornek.com</h5>
                </div>
                <div class="d-flex mb-0">
                    <h5 class="font-weight-semi-bold m-0"><i class="fa fa-phone-alt text-primary mr-3"></i>+90 212 345 67 89</h5>
                </div>
            </div>
            <div class="bg-light p-30 mb-3">
                <h5 class="section-title position-relative text-uppercase mb-4"><span class="bg-secondary pr-3">İletişime Geçin</span></h5>
                <p>Bizimle her türlü soru, öneri veya talebiniz için iletişime geçebilirsiniz. Size yardımcı olmaktan mutluluk duyarız.</p>
            </div>
        </div>
    </div>
</div>

@if (TempData["MessageSent"] != null)
{
    <script>
        Swal.fire({
            title: "Başarılı!",
            text: "Mesajınız alınmıştır. En kısa sürede size dönüş yapılacaktır.",
            icon: "success",
            confirmButtonText: "Tamam",
            confirmButtonColor: "#FFD333" // MultiShop sarı tonu
        });
    </script>
}