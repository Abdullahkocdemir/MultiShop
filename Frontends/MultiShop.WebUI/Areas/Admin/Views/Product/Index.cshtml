@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<MultiShop.DTOLayer.CatalogDTOs.ProductDTO.ResultProductWithCategoryDTO>

@{
    ViewData["Title"] = "Ürün Listesi";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
    int count = (Model.PageNumber - 1) * Model.PageSize;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    .product-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        padding: 25px;
        margin-top: 20px;
    }

    .table thead th {
        background-color: #f8f9fa;
        color: #333;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 11px;
        letter-spacing: 0.5px;
        border-bottom: 2px solid #dee2e6;
        white-space: nowrap;
    }

    .btn-create {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 30px;
        padding: 10px 25px;
        transition: all 0.3s;
        font-weight: 600;
    }

        .btn-create:hover {
            opacity: 0.9;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(118, 75, 162, 0.3);
        }

    .product-img {
        width: 45px;
        height: 45px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid #eee;
        transition: transform 0.2s;
    }

        .product-img:hover {
            transform: scale(1.2);
        }

    .category-badge {
        background-color: #f0f2f5;
        color: #667eea;
        font-weight: 600;
        padding: 5px 12px;
        border-radius: 15px;
        font-size: 0.8rem;
    }

    .feature-badge {
        padding: 5px 10px;
        border-radius: 20px;
        font-size: 10px;
        font-weight: 700;
        text-transform: uppercase;
    }

    .feature-active {
        background-color: #fff9db;
        color: #f08c00;
        border: 1px solid #ffe066;
    }

    .feature-passive {
        background-color: #f8f9fa;
        color: #adb5bd;
        border: 1px solid #e9ecef;
    }

    .action-buttons .btn {
        margin: 2px;
        font-weight: 500;
    }

    .pagination-container {
        margin-top: 25px;
        display: flex;
        justify-content: center;
    }
</style>

<div class="product-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-1" style="font-weight: 700; color: #2d3436;">Ürün Yönetimi</h3>
            <p class="text-muted small mb-0">Ürün listesini yönetin, fiyatları güncelleyin ve görselleri düzenleyin.</p>
        </div>
        <a href="/Admin/Product/CreateProduct/" class="btn btn-create">
            <i class="fa-solid fa-plus me-2"></i> Yeni Ürün Ekle
        </a>
    </div>
    <br />
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th class="text-center">#</th>
                    <th>Görsel</th>
                    <th>Ürün Adı</th>
                    <th>Kategori</th>
                    <th class="text-center">Durum</th>
                    <th>Fiyat</th>
                    <th class="text-center" style="min-width: 380px;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        count++;
                        <tr>
                            <td class="text-center"><span class="text-muted small">@count</span></td>
                            <td>
                                <img src="@item.ProductImageUrl" class="product-img" onerror="this.src='/images/no-image.png'" />
                            </td>
                            <td class="fw-bold text-dark">@item.ProductName</td>
                            <td>
                                <span class="category-badge">
                                    <i class="fa-solid fa-tag me-1"></i>
                                    @(string.IsNullOrEmpty(item.CategoryName) ? "Kategorisiz" : item.CategoryName)
                                </span>
                            </td>
                            <td class="text-center">
                                @if (item.IsFeature)
                                {
                                    <span class="feature-badge feature-active"><i class="fa-solid fa-star"></i> Öne Çıkan</span>
                                }
                                else
                                {
                                    <span class="feature-badge feature-passive"><i class="fa-regular fa-star"></i> Standart</span>
                                }
                            </td>
                            <td>
                                <span class="text-dark fw-bold">@item.ProductPrice.ToString("C2")</span>
                            </td>
                            <td class="text-center action-buttons">
                                <a href="/Admin/ProductImage/ProductImageDetail/@item.ProductId" class="btn btn-outline-info btn-sm rounded-pill px-3">
                                    <i class="fa-solid fa-images me-1"></i> Görseller
                                </a>
                                <a href="/Admin/Product/UpdateProduct/@item.ProductId" class="btn btn-outline-primary btn-sm rounded-pill px-3">
                                    <i class="fa-solid fa-pen-to-square me-1"></i> Düzenle
                                </a>
                                <button onclick="deleteProduct('@item.ProductId', '@item.ProductName')" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                                    <i class="fa-solid fa-trash me-1"></i> Sil
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-5">
                            <i class="fa-solid fa-box-open fa-3x mb-3 text-muted opacity-50"></i>
                            <p class="text-muted">Ürün bulunamadı.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model != null && Model.PageCount > 1)
    {
        <div class="pagination-container">
            @Html.PagedListPager(Model, page => Url.Action("Index", new { page }), new PagedListRenderOptions
            {
                LiElementClasses = new string[] { "page-item" },
                PageClasses = new string[] { "page-link" },
                UlElementClasses = new string[] { "pagination pagination-sm" }
                })
    </div>
        }
</div>

<script>
    function deleteProduct(id, name) {
        Swal.fire({
            title: 'Emin misiniz?',
            text: `"${name}" isimli ürün kalıcı olarak silinecektir!`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#764ba2',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Evet, Sil!',
            cancelButtonText: 'Vazgeç',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = "/Admin/Product/DeleteProduct/" + id;
            }
        });
    }

    @if (TempData["DeleteSuccess"] != null)
    {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Başarılı!',
                    text: '@TempData["DeleteSuccess"]',
                    timer: 2000,
                    showConfirmButton: false
                });
                </text>
    }
</script>