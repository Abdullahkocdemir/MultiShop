@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<MultiShop.DTOLayer.CatalogDTOs.ProductDTO.ResultProductWithCategoryDTO>

@{
    ViewData["Title"] = "Ürün Listesi";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
    int count = (Model.PageNumber - 1) * Model.PageSize;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    .product-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        padding: 25px;
        margin-top: 20px;
    }

    .table thead th {
        background-color: #f8f9fa;
        color: #333;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 11px;
        letter-spacing: 0.5px;
        border-bottom: 2px solid #dee2e6;
    }

    .btn-create {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 30px;
        padding: 10px 25px;
        transition: all 0.3s;
        font-weight: 600;
    }

        .btn-create:hover {
            opacity: 0.9;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(118, 75, 162, 0.3);
        }

    .product-img {
        width: 50px;
        height: 50px;
        object-fit: cover;
        border-radius: 10px;
        border: 2px solid #f0f0f0;
        transition: transform 0.2s;
    }

        .product-img:hover {
            transform: scale(1.1);
        }

    .category-badge {
        background-color: #f0f2f5;
        color: #667eea;
        font-weight: 700;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.85rem;
        border: 1px solid #e0e0e0;
    }

    .feature-badge {
        padding: 6px 12px;
        border-radius: 30px;
        font-size: 11px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        text-transform: uppercase;
    }

    .feature-active {
        background-color: #fff9db;
        color: #f08c00;
        border: 1px solid #ffe066;
    }

    .feature-passive {
        background-color: #f8f9fa;
        color: #adb5bd;
        border: 1px solid #e9ecef;
    }

    .pagination-container {
        margin-top: 25px;
        display: flex;
        justify-content: center;
    }

    .page-item .page-link {
        border: 1px solid #dee2e6;
        padding: 8px 16px;
        margin: 0 3px;
        color: #764ba2;
        border-radius: 6px;
    }

    .page-item.active .page-link {
        background-color: #764ba2;
        border-color: #764ba2;
        color: white;
    }
</style>

<div class="product-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-1" style="font-weight: 700; color: #2d3436;">Ürün Yönetimi</h3>
            <p class="text-muted small mb-0">Katalogdaki ürünlerin listesini, öne çıkan durumlarını ve fiyatlarını yönetin.</p>
        </div>
        <a href="/Admin/Product/CreateProduct/" class="btn btn-create">
            <i class="fa-solid fa-plus me-2"></i> Yeni Ürün Ekle
        </a>
    </div>
    <br />
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th style="width: 50px;">#</th>
                    <th style="width: 80px;">Görsel</th>
                    <th>Ürün Adı</th>
                    <th>Kategori</th>
                    <th class="text-center">Öne Çıkan</th>
                    <th>Fiyat</th>
                    <th class="text-center" style="width: 250px;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        count++;
                        <tr>
                            <td><span class="badge bg-light text-dark border">@count</span></td>
                            <td>
                                <img src="@item.ProductImageUrl" class="product-img" onerror="this.src='/images/no-image.png'" alt="@item.ProductName" />
                            </td>
                            <td class="fw-bold text-dark">@item.ProductName</td>
                            <td>
                                <span class="category-badge">
                                    <i class="fa-solid fa-layer-group me-1 small"></i>
                                    @(string.IsNullOrEmpty(item.CategoryName) ? "Kategorisiz" : item.CategoryName)
                                </span>
                            </td>
                            <td class="text-center">
                                @if (item.IsFeature)
                                {
                                    <span class="feature-badge feature-active">
                                        <i class="fa-solid fa-star"></i> Öne Çıkan
                                    </span>
                                }
                                else
                                {
                                    <span class="feature-badge feature-passive">
                                        <i class="fa-regular fa-star"></i> Standart
                                    </span>
                                }
                            </td>
                            <td>
                                <span class="text-success fw-bold" style="font-size: 1.1rem;">@item.ProductPrice.ToString("C2")</span>
                            </td>
                            <td class="text-center">
                                <a href="/Admin/Product/UpdateProduct/@item.ProductId" class="btn btn-outline-primary btn-sm rounded-pill px-3 me-1">
                                    <i class="fa-solid fa-pen-nib me-1"></i> Düzenle
                                </a>
                                <button onclick="deleteProduct('@item.ProductId', '@item.ProductName')" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                                    <i class="fa-solid fa-trash-can me-1"></i> Sil
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-5">
                            <div class="text-muted">
                                <i class="fa-solid fa-box-open fa-4x mb-3 d-block opacity-50"></i>
                                <h5 class="fw-normal">Henüz kayıtlı bir ürün bulunamadı.</h5>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model != null && Model.PageCount > 1)
    {
        <div class="pagination-container">
            @Html.PagedListPager(Model, page => Url.Action("Index", new { page }), new PagedListRenderOptions
            {
                LiElementClasses = new string[] { "page-item" },
                PageClasses = new string[] { "page-link" },
                UlElementClasses = new string[] { "pagination" }
                })
    </div>
        }
</div>

<script>
    function deleteProduct(id, name) {
        Swal.fire({
            title: 'Emin misiniz?',
            text: `"${name}" isimli ürünü silmek istediğinize emin misiniz?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#764ba2',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Evet, Sil!',
            cancelButtonText: 'Vazgeç',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = "/Admin/Product/DeleteProduct/" + id;
            }
        });
    }

    @if (TempData["DeleteSuccess"] != null)
    {
            <text>
            Swal.fire({
                icon: 'success',
                title: 'Başarılı!',
                text: '@TempData["DeleteSuccess"]',
                timer: 2000,
                showConfirmButton: false
            });
            </text>
    }
</script>