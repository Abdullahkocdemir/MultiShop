@model MultiShop.DTOLayer.CatalogDTOs.ProductImageDTO.ResultProductImageDTO
@{
    ViewData["Title"] = "Görsel Kontrol Merkezi";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<style>
    .image-management-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        padding: 30px;
    }

    .upload-zone {
        border: 2px dashed #d1d9e6;
        border-radius: 15px;
        background: #f8faff;
        transition: 0.3s;
        cursor: pointer;
    }

        .upload-zone:hover {
            border-color: #764ba2;
            background: #f0efff;
        }

    .preview-wrapper {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 15px;
        margin-top: 20px;
    }

    .preview-item {
        position: relative;
        border-radius: 12px;
        overflow: hidden;
        height: 180px;
        border: 2px solid #eee;
        transition: 0.3s;
    }

        .preview-item:hover {
            transform: translateY(-5px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .preview-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .btn-gradient {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
    }

    .remove-btn {
        position: absolute;
        top: 8px;
        right: 8px;
        background: #ff4757;
        color: white;
        border: none;
        border-radius: 50%;
        width: 28px;
        height: 28px;
        cursor: pointer;
        z-index: 20;
        font-weight: bold;
        line-height: 1;
        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
    }

        .remove-btn:hover {
            background: #ff6b81;
        }

    .preview-label {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: rgba(0,0,0,0.6);
        color: white;
        font-size: 10px;
        padding: 4px;
        text-align: center;
    }
</style>

<div class="container py-5">
    <div class="image-management-card">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h3 class="fw-bold text-dark mb-1">📸 Görsel Kontrol Merkezi</h3>
                <p class="text-muted small">Ürün ID: @Model.ProductId</p>
            </div>
            <a href="/Admin/Product/Index" class="btn btn-outline-secondary rounded-pill px-4">Geri Dön</a>
        </div>

        <form asp-action="ProductImageDetail" method="post" enctype="multipart/form-data" id="mainForm">
            <input type="hidden" asp-for="ProductId" />
            <input type="hidden" asp-for="ProductImageId" />

            @* Mevcut yollar (Yeni bir şey yüklenmezse bunları koruyacağız) *@
            <input type="hidden" asp-for="Image1" />
            <input type="hidden" asp-for="Image2" />
            <input type="hidden" asp-for="Image3" />
            <input type="hidden" asp-for="Image4" />

            @* --- ADIM 1: YÜKLEME BUTONU --- *@
            <div class="upload-zone p-4 text-center mb-4" onclick="document.getElementById('tempFileInput').click()">
                <i class="fa-solid fa-circle-plus fa-3x text-primary mb-2 opacity-75"></i>
                <h5 class="fw-bold">Görsel Ekle</h5>
                <p class="text-muted small mb-0">Seçtiğiniz her görsel listeye eklenecektir (Max 4 adet).</p>
                <input type="file" id="tempFileInput" class="d-none" accept="image/*">
            </div>

            @* --- GİZLİ ASIL DOSYA INPUTU (FORMA BU GİDECEK) --- *@
            <input type="file" name="files" id="finalFileInput" multiple class="d-none">

            @* --- ADIM 2: CANLI ÖNİZLEME ALANI --- *@
            <div class="d-flex align-items-center mb-2">
                <span class="fw-bold small text-secondary me-2">YÜKLENECEK GÖRSELLER</span>
                <div class="flex-grow-1 border-bottom"></div>
            </div>

            <div id="previewContainer" class="preview-wrapper">
                @* JS dosyaları buraya ekleyecek *@
                <div id="emptyHint" class="text-muted small italic p-3">Henüz yeni görsel seçilmedi.</div>
            </div>

            @* --- ADIM 3: KAYDET --- *@
            <div class="mt-5 pt-4 border-top">
                <button type="submit" class="btn btn-gradient w-100 py-3 fw-bold rounded-pill shadow-lg">
                    <i class="fa-solid fa-save me-2"></i> Tüm Görselleri Kaydet ve Yayınla
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    // Dosyaları biriktireceğimiz sanal sepet (DataTransfer nesnesi)
    const dt = new DataTransfer();
    const tempInput = document.getElementById('tempFileInput');
    const finalInput = document.getElementById('finalFileInput');
    const container = document.getElementById('previewContainer');
    const emptyHint = document.getElementById('emptyHint');

    tempInput.addEventListener('change', function (e) {
        const files = e.target.files;

        for (let i = 0; i < files.length; i++) {
            // Maksimum 4 adet kontrolü
            if (dt.items.length < 4) {
                dt.items.add(files[i]);
            } else {
                alert("Maksimum 4 adet görsel yükleyebilirsiniz!");
                break;
            }
        }

        // Asıl inputu güncelle ve önizlemeyi tazele
        syncAndRender();
        // Inputu temizle (Aynı dosyayı tekrar seçebilmek için)
        tempInput.value = "";
    });

    function syncAndRender() {
        // 1. Asıl formu gönderecek olan inputu güncelle
        finalInput.files = dt.files;

        // 2. Önizleme alanını temizle
        container.innerHTML = '';

        if (dt.items.length === 0) {
            container.appendChild(emptyHint);
            return;
        }

        // 3. Sepetteki her dosyayı ekrana bas
        Array.from(dt.files).forEach((file, index) => {
            const reader = new FileReader();
            reader.onload = function (event) {
                const div = document.createElement('div');
                div.className = 'preview-item';
                div.innerHTML = `
                    <button type="button" class="remove-btn" onclick="removeFile(${index})">&times;</button>
                    <img src="${event.target.result}">
                    <div class="preview-label">Sıra: ${index + 1}</div>
                `;
                container.appendChild(div);
            }
            reader.readAsDataURL(file);
        });
    }

    function removeFile(index) {
        // Sepeti temizle ve silinen hariç geri doldur
        const newDt = new DataTransfer();
        const files = dt.files;

        for (let i = 0; i < files.length; i++) {
            if (i !== index) {
                newDt.items.add(files[i]);
            }
        }

        // Mevcut sepeti güncelle
        dt.items.clear();
        Array.from(newDt.files).forEach(f => dt.items.add(f));

        syncAndRender();
    }
</script>