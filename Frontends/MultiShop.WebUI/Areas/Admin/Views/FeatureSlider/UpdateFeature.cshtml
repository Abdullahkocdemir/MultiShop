@model MultiShop.DTOLayer.CatalogDTOs.FeatureSliderDTO.UpdateFeatureDTO

@{
    ViewData["Title"] = "Öne Çıkan Güncelle";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<div class="row justify-content-start">
    <div class="col-md-8">
        <div class="form-card" style="background: #fff; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); padding: 30px; margin-top: 20px;">
            <h3 class="mb-1">İçeriği Güncelle</h3>
            <p class="text-muted small mb-4">Mevcut bilgileri düzenleyebilir veya görseli değiştirebilirsiniz.</p>

            <form method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="FeatureSliderId" />
                <input type="hidden" asp-for="ImageUrl" /> @* Yeni resim seçilmezse eski yol korunur *@

                <div class="mb-3">
                    <label class="form-label fw-bold">Başlık</label>
                    <input type="text" asp-for="Title" class="form-control" required>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Açıklama</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Slider Görseli</label>
                    <div class="mb-2">
                        <small class="text-muted">Şu anki görsel:</small><br />
                        <img id="imgUpdatePreview" src="@Model.ImageUrl" style="width:100%; max-width:300px; border-radius:10px; border:1px solid #ddd;" />
                    </div>
                    <label class="small text-primary fw-bold">Yeni bir görsel seçmek için tıklayın (Opsiyonel):</label>
                    <input type="file" name="ImageFile" class="form-control" accept="image/*" onchange="updatePreview(this)">
                </div>

                <div class="mb-4">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" asp-for="Status">
                        <label class="form-check-label fw-bold">Yayında Olsun</label>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-5" style="border-radius: 30px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border:none;">
                        <i class="fa-solid fa-arrows-rotate"></i> Güncellemeyi Kaydet
                    </button>
                    <a href="/Admin/Feature/Index" class="btn btn-outline-secondary px-4" style="border-radius: 30px;">Vazgeç</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function updatePreview(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('imgUpdatePreview').src = e.target.result;
            }
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>