@model List<MultiShop.DTOLayer.CatalogDTOs.FeatureDTO.ResultFeatureDTO>

@{
    ViewData["Title"] = "Öne Çıkan Listesi";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="category-card" style="background: #fff; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); padding: 25px; margin-top: 20px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-1">Öne Çıkan İçerik Yönetimi</h3>
            <p class="text-muted small">Slider alanındaki görselleri ve içerikleri buradan yönetebilirsiniz.</p>
        </div>
        <a href="/Admin/FeatureSlider/CreateFeature/" class="btn btn-primary" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border:none; border-radius: 30px; padding: 10px 25px;">
            <i class="fa-solid fa-plus"></i> Yeni İçerik Ekle
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th style="width: 50px;">#</th>
                    <th style="width: 120px;">Görsel</th>
                    <th>Başlık</th>
                    <th>Durum</th>
                    <th class="text-center" style="width: 200px;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    @foreach (var item in Model)
                    {
                        count++;
                        <tr>
                            <td><span class="badge bg-light text-dark">@count</span></td>
                            <td>
                                <img src="@item.ImageUrl" style="width:100px; height:55px; object-fit:cover; border-radius:8px; border:1px solid #eee;"
                                     onerror="this.src='/images/no-image.png'" />
                            </td>
                            <td class="fw-bold text-dark">@item.Title</td>
                            <td>
                                <span class="badge @(item.Status ? "bg-success" : "bg-danger")">
                                    @(item.Status ? "Aktif" : "Pasif")
                                </span>
                            </td>
                            <td class="text-center">
                                <a href="/Admin/FeatureSlider/UpdateFeature/@item.FeatureSliderId" class="btn btn-outline-primary btn-sm rounded-pill px-3">
                                    <i class="fa-solid fa-pen-to-square"></i> Düzenle
                                </a>
                                <button onclick="deleteFeature('@item.FeatureSliderId', '@item.Title')" class="btn btn-outline-danger btn-sm rounded-pill px-3 ms-1">
                                    <i class="fa-solid fa-trash"></i> Sil
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function deleteFeature(id, name) {
        Swal.fire({
            title: 'Emin misiniz?',
            text: `"${name}" içeriği silinecektir. Bu işlem geri alınamaz!`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            confirmButtonText: 'Evet, Sil!',
            cancelButtonText: 'İptal'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = "/Admin/FeatureSlider/DeleteFeature/" + id;
            }
        });
    }
</script>