@model CreateSpecialOfferDTO
@{
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<div class="row justify-content-start">
    <div class="col-md-8">
        <div class="form-card" style="background: #fff; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); padding: 30px; margin-top: 20px;">
            <h3 class="mb-4">Yeni Özel Teklif</h3>
            <form method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label class="form-label fw-bold">Başlık</label>
                    <input type="text" asp-for="Title" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Alt Başlık</label>
                    <input type="text" asp-for="SubTitle" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Görsel Seç</label>
                    <input type="file" name="ImageFile" class="form-control" accept="image/*" required>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4" style="border-radius:30px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border:none;">Kaydet</button>
                    <a href="/Admin/SpecialOffer/Index" class="btn btn-outline-secondary px-4" style="border-radius:30px;">İptal</a>
                </div>
            </form>
        </div>
    </div>
</div>