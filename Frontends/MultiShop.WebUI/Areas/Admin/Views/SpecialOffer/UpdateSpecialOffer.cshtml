@model UpdateSpecialOfferDTO
@{
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<div class="row justify-content-start">
    <div class="col-md-8">
        <div class="form-card" style="background: #fff; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); padding: 30px; margin-top: 20px;">
            <h3 class="mb-4">Teklifi Güncelle</h3>
            <form method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="SpecialOfferId" />
                <input type="hidden" asp-for="ImageUrl" />

                <div class="mb-3">
                    <label class="form-label fw-bold">Başlık</label>
                    <input type="text" asp-for="Title" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Alt Başlık</label>
                    <input type="text" asp-for="SubTitle" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Mevcut Görsel</label><br />
                    <img src="@Model.ImageUrl" style="width:150px; border-radius:8px; border:1px solid #ddd; margin-bottom:10px;" />
                    <input type="file" name="ImageFile" class="form-control" accept="image/*">
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4" style="border-radius:30px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border:none;">Güncelle</button>
                    <a href="/Admin/SpecialOffer/Index" class="btn btn-outline-secondary px-4" style="border-radius:30px;">Vazgeç</a>
                </div>
            </form>
        </div>
    </div>
</div>