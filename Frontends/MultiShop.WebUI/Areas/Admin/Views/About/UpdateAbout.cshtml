@using MultiShop.DTOLayer.CatalogDTOs.AboutDTO
@model UpdateAboutDTO
@{
    ViewData["Title"] = "Bilgileri Güncelle";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<div class="row justify-content-start">
    <div class="col-md-9">
        <div class="card border-0 shadow-sm p-4 mt-4" style="border-radius: 12px;">
            <h3 class="fw-bold mb-4">Kurumsal Bilgileri Düzenle</h3>
            <form method="post">
                <input type="hidden" asp-for="AboutId" />

                <div class="mb-4">
                    <label class="form-label fw-bold text-primary">Hakkımızda Açıklaması</label>
                    <textarea asp-for="Description" class="form-control" rows="6" required></textarea>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">E-Posta</label>
                        <input type="email" asp-for="Email" class="form-control" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Telefon</label>
                        <input type="text" asp-for="Phone" class="form-control" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Adres Bilgisi</label>
                    <input type="text" asp-for="Address" class="form-control" required />
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-success rounded-pill px-4">Değişiklikleri Güncelle</button>
                    <a href="/Admin/About/Index" class="btn btn-light rounded-pill px-4">Geri Dön</a>
                </div>
            </form>
        </div>
    </div>
</div>