@using MultiShop.DTOLayer.CatalogDTOs.AboutDTO
@model CreateAboutDTO
@{
    ViewData["Title"] = "Yeni Kurumsal Bilgi";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<div class="row justify-content-start">
    <div class="col-md-9">
        <div class="card border-0 shadow-sm p-4 mt-4" style="border-radius: 12px;">
            <h3 class="fw-bold mb-4">Yeni Kurumsal Bilgi Ekle</h3>
            <form method="post">
                <div class="mb-4">
                    <label class="form-label fw-bold">Hakkımızda Açıklaması</label>
                    <textarea asp-for="Description" class="form-control" rows="5" placeholder="Şirket tarihçesi veya tanıtım yazısı..." required></textarea>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">E-Posta Adresi</label>
                        <input type="email" asp-for="Email" class="form-control" placeholder="destek@multishop.com" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Telefon Numarası</label>
                        <input type="text" asp-for="Phone" class="form-control" placeholder="0212 XXX XX XX" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Fiziksel Adres</label>
                    <input type="text" asp-for="Address" class="form-control" placeholder="Mahalle, Sokak, No, İlçe/İl" required />
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Kaydet</button>
                    <a href="/Admin/About/Index" class="btn btn-light rounded-pill px-4">Vazgeç</a>
                </div>
            </form>
        </div>
    </div>
</div>