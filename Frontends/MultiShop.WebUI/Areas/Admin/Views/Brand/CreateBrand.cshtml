@model CreateBrandDTO
@{
    ViewData["Title"] = "Marka Ekle";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<div class="container-fluid py-4">
    <div class="card border-0 shadow-sm col-md-6">
        <div class="card-body p-4">
            <h4 class="fw-bold mb-3">Yeni Marka Tanımla</h4>
            <form method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label class="form-label fw-600">Marka Adı</label>
                    <input type="text" asp-for="BrandName" class="form-control" placeholder="Örn: Samsung" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-600">Marka Logosu</label>
                    <input type="file" name="ImageFile" class="form-control" accept="image/*" onchange="previewImage(this)" />
                    <img id="logoPreview" src="#" style="display:none; width: 120px; margin-top:15px; border-radius: 8px;" />
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Kaydet</button>
                    <a href="/Admin/Brand/Index" class="btn btn-light rounded-pill px-4">Geri Dön</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function previewImage(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = e => {
                const img = document.getElementById('logoPreview');
                img.src = e.target.result;
                img.style.display = 'block';
            }
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>