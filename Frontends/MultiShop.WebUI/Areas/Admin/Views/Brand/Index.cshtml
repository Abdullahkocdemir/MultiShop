@model List<MultiShop.DTOLayer.CatalogDTOs.BrandDTO.ResultBrandDTO>

@{
    ViewData["Title"] = "Marka Listesi";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    .brand-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        padding: 25px;
        margin-top: 20px;
    }

    .table thead th {
        background-color: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
        color: #333;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 12px;
        letter-spacing: 0.5px;
    }

    .brand-img {
        width: 50px;
        height: 50px;
        object-fit: contain;
        border-radius: 10px;
        border: 2px solid #f0f0f0;
        padding: 3px;
        background-color: #fff;
        transition: transform 0.2s;
    }

        .brand-img:hover {
            transform: scale(1.15);
        }

    .btn-action {
        border-radius: 8px;
        padding: 6px 14px;
        font-weight: 500;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
    }

        .btn-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.12);
        }

    .btn-create {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        padding: 10px 22px;
        border-radius: 30px;
        font-weight: 600;
    }

        .btn-create:hover {
            color: white;
            opacity: 0.95;
        }

    .badge-id {
        background-color: #f1f3f5;
        color: #495057;
        padding: 4px 10px;
        border-radius: 6px;
        font-weight: 600;
    }
</style>

<section class="content container-fluid">
    <div class="row">
        <div class="col-md-12">
            <div class="brand-card">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h3 class="mb-1" style="font-weight: 700; color: #2d3436;">Marka Yönetimi</h3>
                        <p class="text-muted small">İş ortağımız olan markaları, logoları ve görünürlük durumlarını buradan yönetin.</p>
                    </div>
                    <a href="/Admin/Brand/CreateBrand/" class="btn btn-create btn-action">
                        <i class="fa-solid fa-plus"></i> Yeni Marka Ekle
                    </a>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th style="width: 60px;">#</th>
                                <th style="width: 120px;">Logo</th>
                                <th>Marka Adı</th>
                                <th class="text-center" style="width: 250px;">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Count > 0)
                            {
                                @foreach (var item in Model)
                                {
                                    count++;
                                    <tr>
                                        <td><span class="badge-id">@count</span></td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                                            {
                                                <img src="@item.ImageUrl" class="brand-img" alt="@item.BrandName" />
                                            }
                                            else
                                            {
                                                <img src="/BrandImages/no-image.png" class="brand-img" alt="Görsel Yok" />
                                            }
                                        </td>
                                        <td>
                                            <span class="fw-bold text-dark" style="font-size: 15px;">@item.BrandName</span>
                                        </td>
                                        <td class="text-center">
                                            <a href="/Admin/Brand/UpdateBrand/@item.BrandId" class="btn btn-action btn-outline-primary btn-sm me-2">
                                                <i class="fa-solid fa-pen-to-square"></i> Düzenle
                                            </a>
                                            <button onclick="deleteBrand('@item.BrandId', '@item.BrandName')" class="btn btn-action btn-outline-danger btn-sm">
                                                <i class="fa-solid fa-trash-can"></i> Sil
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-5">
                                        <div class="mb-3">
                                            <i class="fa-solid fa-copyright fa-3x text-muted" style="opacity: 0.5;"></i>
                                        </div>
                                        <p class="text-muted fw-bold">Henüz hiç marka eklenmemiş.</p>
                                        <a href="/Admin/Brand/CreateBrand/" class="btn btn-sm btn-primary">İlk Markayı Ekle</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    function deleteBrand(id, name) {
        Swal.fire({
            title: 'Emin misiniz?',
            text: `"${name}" markası sistemden tamamen silinecektir.`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            confirmButtonColor: '#d33',
            cancelButtonColor: '#adb5bd',
            confirmButtonText: 'Evet, Sil!',
            cancelButtonText: 'Vazgeç',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = "/Admin/Brand/DeleteBrand/" + id;
            }
        });
    }
</script>