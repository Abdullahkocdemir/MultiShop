@model List<MultiShop.DTOLayer.CatalogDTOs.OfferDiscountDTO.ResultOfferDiscountDTO>

@{
    ViewData["Title"] = "İndirim Teklifleri";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    .offer-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        padding: 25px;
        margin-top: 20px;
    }

    .offer-img {
        width: 80px;
        height: 45px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid #eee;
    }

    .btn-create {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        padding: 10px 22px;
        border-radius: 30px;
        font-weight: 600;
    }

    .btn-action {
        border-radius: 8px;
        padding: 6px 14px;
        font-size: 13px;
        transition: all 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
</style>

<div class="offer-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold">İndirim Teklifleri</h3>
            <p class="text-muted small">Ana sayfadaki büyük indirim bannerlarını ve kampanya tekliflerini yönetin.</p>
        </div>
        <a href="/Admin/OfferDiscount/CreateOfferDiscount/" class="btn btn-create btn-action">
            <i class="fa-solid fa-plus"></i> Yeni Teklif Ekle
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width: 50px;">#</th>
                    <th style="width: 100px;">Görsel</th>
                    <th>Başlık</th>
                    <th>Alt Başlık</th>
                    <th class="text-center">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    @foreach (var item in Model)
                    {
                        count++;
                        <tr>
                            <td><span class="badge bg-light text-dark p-2">@count</span></td>
                            <td><img src="@item.ImageUrl" class="offer-img" /></td>
                            <td><span class="fw-bold">@item.Title</span></td>
                            <td class="text-muted">@item.SubTitle</td>
                            <td class="text-center">
                                <a href="/Admin/OfferDiscount/UpdateOfferDiscount/@item.OfferDiscountId" class="btn btn-action btn-outline-primary btn-sm me-1">Düzenle</a>
                                <button onclick="deleteOffer('@item.OfferDiscountId', '@item.Title')" class="btn btn-action btn-outline-danger btn-sm">Sil</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function deleteOffer(id, title) {
        Swal.fire({
            title: 'Emin misiniz?',
            text: `"${title}" kampanyası silinecek.`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            confirmButtonText: 'Evet, Sil',
            cancelButtonText: 'Vazgeç'
        }).then((result) => {
            if (result.isConfirmed) window.location.href = "/Admin/OfferDiscount/DeleteOfferDiscount/" + id;
        });
    }
</script>