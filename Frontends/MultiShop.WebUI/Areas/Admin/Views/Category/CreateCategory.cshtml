@model CreateCategoryDTO

@{
    ViewData["Title"] = "Yeni Kategori Ekle";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

@* FontAwesome İkonları *@
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<style>
    .form-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        padding: 30px;
        margin-top: 20px;
        max-width: 600px;
    }

    .form-label {
        font-weight: 600;
        color: #495057;
        margin-bottom: 8px;
    }

    .form-control {
        border-radius: 8px;
        padding: 12px;
        border: 1px solid #dee2e6;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            border-color: #667eea;
            box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
        }

    .btn-save {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 30px;
        font-weight: 500;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
            color: white;
            opacity: 0.9;
        }

    .btn-back {
        border-radius: 30px;
        padding: 12px 25px;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
</style>

<div class="row justify-content-start">
    <div class="col-md-8">
        <div class="form-card">
            <div class="mb-4">
                <h3 class="mb-1">Yeni Kategori Oluştur</h3>
                <p class="text-muted small">Sisteme yeni bir ürün kategorisi tanımlamak için aşağıdaki alanı doldurun.</p>
            </div>

            <form method="post">
                <div class="mb-4">
                    <label asp-for="CategoryName" class="form-label">Kategori Adı</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="fa-solid fa-tag text-muted"></i>
                        </span>
                        <input type="text" asp-for="CategoryName" class="form-control border-start-0" placeholder="Örn: Elektronik, Moda, Ev & Yaşam" required>
                    </div>
                    <span asp-validation-for="CategoryName" class="text-danger small"></span>
                </div>
                <br />
                <div class="d-flex gap-2 pt-2">
                    <button type="submit" class="btn btn-save">
                        <i class="fa-solid fa-floppy-disk"></i> Kategoriyi Kaydet
                    </button>
                    <a href="/Admin/Category/Index" class="btn btn-outline-secondary btn-back">
                        <i class="fa-solid fa-arrow-left"></i> Vazgeç
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
