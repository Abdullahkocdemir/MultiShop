@model List<MultiShop.DTOLayer.CatalogDTOs.CategoryDTO.ResultCategoryDTO>

@{
    ViewData["Title"] = "Kategori Listesi";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

@* Gerekli Kütüphaneler *@
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    .category-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        padding: 25px;
        margin-top: 20px;
    }

    .table thead th {
        background-color: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
        color: #333;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 13px;
    }

    .btn-action {
        border-radius: 8px;
        padding: 6px 16px;
        font-weight: 500;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.15);
        }

    .btn-create {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        padding: 10px 25px;
        border-radius: 30px;
    }

        .btn-create:hover {
            color: white;
            opacity: 0.9;
        }

    .badge-id {
        background-color: #e9ecef;
        color: #495057;
        padding: 5px 10px;
        border-radius: 6px;
        font-family: 'Courier New', Courier, monospace;
    }
</style>

<section class="content container-fluid">
    <div class="row">
        <div class="col-md-12">
            <div class="category-card">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h3 class="mb-1">Kategori Yönetimi</h3>
                        <p class="text-muted small">Katalog sistemindeki tüm kategorileri buradan yönetebilirsiniz.</p>
                    </div>
                    <a href="/Admin/Category/CreateCategory/" class="btn btn-create btn-action">
                        <i class="fa-solid fa-plus"></i> Yeni Kategori Ekle
                    </a>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th style="width: 80px;">#</th>
                                <th>Kategori Adı</th>
                                <th class="text-center" style="width: 250px;">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Count > 0)
                            {
                                @foreach (var item in Model)
                                {
                                    count++;
                                    <tr>
                                        <td><span class="badge-id">@count</span></td>
                                        <td class="fw-bold text-dark">@item.CategoryName</td>
                                        <td class="text-center">
                                            <a href="/Admin/Category/UpdateCategory/@item.CategoryId" class="btn btn-action btn-outline-primary btn-sm me-2">
                                                <i class="fa-solid fa-pen-to-square"></i> Düzenle
                                            </a>
                                            <button onclick="deleteCategory('@item.CategoryId', '@item.CategoryName')" class="btn btn-action btn-outline-danger btn-sm">
                                                <i class="fa-solid fa-trash-can"></i> Sil
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center py-5">
                                        <i class="fa-solid fa-folder-open fa-3x text-muted mb-3"></i>
                                        <p class="text-muted">Henüz hiç kategori eklenmemiş.</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

@* JavaScript İşlemleri *@
<script>
    function deleteCategory(id, name) {
        Swal.fire({
            title: 'Emin misiniz?',
            text: `"${name}" kategorisi silinecektir. Bu işlem geri alınamaz!`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Evet, Sil!',
            cancelButtonText: 'İptal',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                // Controller'daki DeleteAction'a yönlendiriyoruz
                window.location.href = "/Admin/Category/DeleteCategory/" + id;
            }
        });
    }

    // Eğer Controller'dan silme başarılı mesajı gelirse (TempData ile)
    @if (TempData["DeleteSuccess"] != null)
    {
            <text>
            const Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true
            });
            Toast.fire({
                icon: 'success',
                title: '@TempData["DeleteSuccess"]'
            });
            </text>
    }
</script>